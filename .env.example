# Local development (on-call-guardian docker-compose)
MONGO_USER=analytics
MONGO_PASSWORD=analytics-local-dev
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=analytics

# Production (AWS DocumentDB) — uncomment and fill in
# MONGO_URI=mongodb://on-call-guardian:<password>@<host>:27017/analytics?tls=true&retryWrites=false&tlsAllowInvalidHostnames=true&authSource=admin
# MONGO_TLS_CA_FILE=/usr/local/share/ca-certificates/global-bundle.pem
